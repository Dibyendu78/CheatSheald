# ─────────────────────────────────────────────────────────────────────
# Anti-Cheating System — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────

# ── Redis (AWS ElastiCache Serverless) ────────────────────────────────
REDIS_HOST=anticheatredis-qzzou5.serverless.aps1.cache.amazonaws.com
REDIS_PORT=6379

# ── API Instance ──────────────────────────────────────────────────────
# Defaults to container hostname (unique per scaled instance).
# Override only if you need a fixed name.
# API_INSTANCE_ID=api-1

# ── Backpressure ──────────────────────────────────────────────────────
# Max frames allowed in queue before new frames are dropped.
BACKPRESSURE_LIMIT=500

# ── Per-user Rate Limiting ────────────────────────────────────────────
# Max frames per second accepted from a single student.
MAX_FPS_PER_USER=3

# ── Worker ML Settings ────────────────────────────────────────────────
# Path where model files are mounted inside the worker container.
MODELS_DIR=/app

# Max inference time in seconds before the frame is aborted (0 = off).
INFERENCE_TIMEOUT_SEC=10

# Max allowed base64 frame size in bytes (default 800 KB).
MAX_FRAME_B64_BYTES=819200

# ── Monitoring ────────────────────────────────────────────────────────
# How often (seconds) to log queue size / cache stats when idle.
MONITOR_INTERVAL=30

# ── Redis Startup Retry ───────────────────────────────────────────────
# Number of connection attempts before giving up.
REDIS_CONNECT_RETRIES=10
# Base delay in seconds (doubles each attempt: 2, 4, 8, 16 ...).
REDIS_RETRY_BASE_DELAY=2.0
